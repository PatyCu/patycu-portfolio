---
import Header from "../components/layout/Header.astro"
import Footer from "../components/layout/Footer.astro"
import patycuAvatar from "../img/patycu_avatar.png"
import "@fontsource/barlow"
import "@fontsource/jetbrains-mono"
import "../styles/global.css"

interface Props {
    title: string
    description: string
    theme?: "legacy" | "light"
}

const { title, description, theme = "legacy" } = Astro.props
const isLight = theme === "light"
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url)
const socialImageUrl = new URL(patycuAvatar.src, Astro.site ?? Astro.url)
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={socialImageUrl} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImageUrl} />
        <title>{title}</title>
    </head>
    <body class:list={[isLight ? "bg-cream text-ink" : "theme-legacy bg-dark-turquoise text-[#d8f2f6]"]}>
        {
            !isLight && (
                <div class="absolute h-full w-full overflow-hidden border border-transparent" aria-hidden="true">
                    <div class="absolute bottom-0 left-[-20%] right-0 top-[-10%] size-[500px] rounded-full bg-[radial-gradient(circle_farthest-side,rgba(255,0,182,.15),rgba(255,255,255,0))] xl:h-[1000px] xl:w-[1500px]" />
                    <div class="absolute bottom-0 right-[-20%] top-[-10%] size-[500px] rounded-full bg-[radial-gradient(circle_farthest-side,rgba(255,0,182,.15),rgba(255,255,255,0))] xl:size-[1100px]" />
                </div>
            )
        }
        <div class="relative min-h-screen">
            <div class:list={["relative mx-auto max-w-7xl", isLight ? "px-5 sm:px-8" : "p-8 md:p-12"]}>
                <Header theme={theme} />
                <slot />
                <Footer theme={theme} />
            </div>
        </div>
    </body>
</html>
