---
import Layout from "./Layout.astro"
import TagList from "../components/blog/TagList.astro"

const { frontmatter } = Astro.props
---

<Layout title={frontmatter.title} description={frontmatter.description} theme="light">
    <main class="mx-auto w-full pb-24" id="top">
        <article class="mx-auto max-w-4xl pb-12 pt-12 sm:pt-16 md:pt-24">
            <a
                href="/blog"
                class="inline-flex rounded-sm text-sm font-black text-sea transition-colors hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-coral"
            >
                &larr; Back to all writing
            </a>

            <header class="mt-10 border-b border-ink/10 pb-10 md:mt-14 md:pb-14">
                <p class="mb-5 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-coral">
                    Notes from the field
                </p>
                <h1
                    class="text-balance text-4xl font-black leading-[0.98] tracking-[-0.045em] text-ink sm:text-5xl md:text-6xl"
                >
                    {frontmatter.title}
                </h1>
                <div class="mt-7 flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-xs text-ink-muted">
                    <time datetime={frontmatter.pubDate.slice(0, 10)}>{frontmatter.pubDate.slice(0, 10)}</time>
                    <span class="size-1 rounded-full bg-coral" aria-hidden="true"></span>
                    <span>By {frontmatter.author}</span>
                </div>
            </header>

            {
                frontmatter.quote && (
                    <blockquote class="my-10 rounded-3xl border border-sea/15 bg-sea/10 p-6 font-display text-2xl italic leading-relaxed text-ink sm:p-8 sm:text-3xl md:my-14">
                        <span class="mb-3 block font-mono text-sm not-italic text-sea" aria-hidden="true">
                            “
                        </span>
                        <p>{frontmatter.quote}</p>
                    </blockquote>
                )
            }

            <div class="blog-prose">
                <slot />
            </div>

            {
                frontmatter.tags?.length > 0 && (
                    <footer class="mt-14 border-t border-ink/10 pt-8">
                        <p class="mb-4 font-mono text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-ink-muted">
                            Topics in this article
                        </p>
                        <TagList tags={frontmatter.tags} />
                    </footer>
                )
            }
        </article>
    </main>
</Layout>

<style is:global>
    .blog-prose {
        color: var(--color-ink-muted);
        font-size: 1.125rem;
        line-height: 1.8;
    }

    .blog-prose > * + * {
        margin-top: 1.5rem;
    }

    .blog-prose h2,
    .blog-prose h3 {
        color: var(--color-ink);
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-top: 3rem;
    }

    .blog-prose h2 {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
    }

    .blog-prose h3 {
        font-size: 1.5rem;
    }

    .blog-prose a {
        color: var(--color-sea);
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 0.2em;
    }

    .blog-prose a:focus-visible {
        border-radius: 0.125rem;
        outline: 2px solid var(--color-coral);
        outline-offset: 0.25rem;
    }

    .blog-prose code {
        border-radius: 0.35rem;
        background: color-mix(in srgb, var(--color-sea) 12%, transparent);
        color: var(--color-ink);
        font-family: var(--font-mono);
        font-size: 0.88em;
        padding: 0.15em 0.35em;
    }

    .blog-prose img {
        border-radius: 1.5rem;
        box-shadow: var(--shadow-soft);
    }
</style>
