---
import Layout from "../layouts/Layout.astro"
import Hero from "../components/hero/Hero.astro"
import ProfileSummary from "../components/profile/ProfileSummary.astro"
import InteractiveCv from "../features/interactive-cv/InteractiveCv"
import Recommendations from "../components/recommendations/Recommendations.astro"
---

<Layout
    title="Paty Cuenca — Engineering Leader and Product Engineer"
    description="Paty Cuenca is a Senior Engineering Manager and product engineer at heart, with 20 years in technology and 14 years leading autonomous, high-performing engineering teams."
    theme="light"
>
    <main class="mx-auto w-full" id="top">
        <Hero />
        <ProfileSummary />
        <InteractiveCv client:load />
        <section class="scroll-mt-24 pb-24 md:pb-32" id="recommendations" aria-labelledby="recommendations-heading">
            <div class="mb-8">
                <p class="mb-3 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-coral">
                    /* what the humans say */
                </p>
                <h2
                    id="recommendations-heading"
                    class="max-w-3xl text-3xl font-black leading-tight tracking-[-0.035em] text-ink md:text-5xl"
                >
                    Kind words from people <span class="font-display font-normal italic">I've worked with</span>
                </h2>
                <p class="mt-4 font-mono text-xs text-ink-muted">cat ~/feedback/peer-reviews.md</p>
            </div>
            <Recommendations />
        </section>
    </main>
</Layout>
