---
import Layout from "../layouts/Layout.astro"
import Hero from "../components/hero/Hero.astro"
import ProfileSummary from "../components/profile/ProfileSummary.astro"
import ExperienceExplorer from "../features/interactive-cv/ExperienceExplorer"
import ProjectExplorer from "../features/interactive-cv/ProjectExplorer"
import Education from "../components/education/Education.astro"
import Recommendations from "../components/recommendations/Recommendations.astro"
import OffHours from "../components/off-hours/OffHours.astro"
---

<Layout
    title="Paty Cuenca — Engineering Leader and Product Engineer"
    description="Paty Cuenca is a Senior Engineering Manager and product engineer at heart, with 20 years in technology and 14 years leading autonomous, high-performing engineering teams."
    theme="light"
>
    <main class="mx-auto w-full" id="top">
        <Hero />
        <ProfileSummary />
        <ExperienceExplorer client:load />
        <ProjectExplorer client:load />
        <Education />
        <section
            class="relative mb-24 scroll-mt-24 rounded-3xl border-2 border-dashed border-sea/25 bg-sea/10 p-6 sm:p-8 md:mb-32 md:p-14"
            id="recommendations"
            aria-labelledby="recommendations-heading"
        >
            <div
                class="absolute -top-4 left-6 rounded-full bg-sea px-3 py-1 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-cream sm:left-8"
            >
                /* what the humans say */
            </div>
            <div class="mb-10 mt-2 text-center md:mb-14">
                <h2
                    id="recommendations-heading"
                    class="mx-auto max-w-4xl text-3xl font-black leading-tight tracking-[-0.035em] text-ink md:text-5xl"
                >
                    Kind words from
                    <span
                        class="font-display font-normal italic text-sea underline decoration-sea decoration-2 decoration-wavy underline-offset-8"
                    >
                        people I've worked with
                    </span>
                </h2>
            </div>
            <Recommendations />
        </section>
        <OffHours />
    </main>
</Layout>
