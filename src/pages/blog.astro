---
export const prerender = false

import BlogPost from "../components/blog/BlogPost.astro"
import TagList from "../components/blog/TagList.astro"
import Layout from "../layouts/Layout.astro"

const pageTitle = "An Engineering Manager in the wild appears!"
const allPosts = Object.values(import.meta.glob("./posts/*.md", { eager: true }))

const activeTag = Astro.url.searchParams.get("tag") ?? undefined

// Collect unique tags across all posts
const allTags = [...new Set(allPosts.flatMap((post: any) => post.frontmatter?.tags ?? []))]

const visiblePosts = activeTag
    ? allPosts.filter((post: any) => post.frontmatter?.tags?.includes(activeTag))
    : allPosts
---

<Layout
    title={pageTitle}
    description="Blog about Engineering Management, leadership, and in general navigating the difficult but rewarding tech industry"
>
    <div class="flex flex-row items-baseline">
        <div class="basis-5/6">
            <section class="mt-12">
                <h1>{pageTitle}</h1>
                {
                    visiblePosts.reverse().map((post) => (
                        <article>
                            <BlogPost post={post} />
                        </article>
                    ))
                }
            </section>
        </div>
        <nav class="basis-1/6">
            <h3 class="text-white text-sm font-semibold uppercase tracking-wider mb-3">Tags</h3>
            {
                activeTag && (
                    <a
                        href="/blog"
                        class="block mb-3 text-sm text-slate-300/70 hover:text-cyan-500 transition-colors"
                    >
                        &larr; All posts
                    </a>
                )
            }
            <TagList tags={allTags} activeTag={activeTag} />
        </nav>
    </div>
</Layout>
