---
import { RECOMMENDATIONS } from "../../data/RECOMMENDATIONS"
import RecommendationItem from "./RecommendationItem.astro"
---

<ol class="flex flex-col gap-4">
    {
        RECOMMENDATIONS.map((recommendation) => {
            return (
                <li>
                    <RecommendationItem {recommendation} />
                </li>
            )
        })
    }
</ol>
