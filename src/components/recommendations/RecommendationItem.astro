---
import type { Recommendation } from "../../data/RECOMMENDATIONS"

interface Props {
    recommendation: Recommendation
}

const { recommendation } = Astro.props
const initials = recommendation.name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
const [opening, ...remainder] = recommendation.recommendation
---

<article class="flex h-full flex-col rounded-3xl border border-ink/5 bg-white p-6 md:p-8">
    <blockquote class="flex flex-1 flex-col">
        <span class="font-display text-6xl leading-none text-coral" aria-hidden="true">“</span>
        <p class="-mt-3 text-base font-semibold leading-relaxed text-ink md:text-lg">{opening}</p>

        {
            remainder.length > 0 && (
                <details class="group mt-4">
                    <summary class="w-fit cursor-pointer rounded font-mono text-[0.65rem] font-semibold uppercase tracking-[0.12em] text-sea marker:hidden hover:underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-coral">
                        <span class="group-open:hidden">Read full recommendation ↓</span>
                        <span class="hidden group-open:inline">Show less ↑</span>
                    </summary>
                    <div class="mt-4 space-y-4 text-sm leading-relaxed text-ink-muted">
                        {remainder.map((paragraph) => (
                            <p>{paragraph}</p>
                        ))}
                    </div>
                </details>
            )
        }
    </blockquote>

    <footer class="mt-8 flex items-center gap-4 border-t border-ink/10 pt-5">
        <span
            class="grid size-11 shrink-0 place-items-center rounded-full bg-dark-turquoise font-mono text-xs font-bold text-cream"
            aria-hidden="true"
        >
            {initials}
        </span>
        <div class="min-w-0">
            <p class="font-black leading-tight text-ink">{recommendation.name}</p>
            <p class="mt-1 text-xs leading-relaxed text-ink-muted">
                {recommendation.position} · {recommendation.experience} · {recommendation.location}
            </p>
            <p class="mt-1 font-mono text-[0.6rem] uppercase tracking-[0.1em] text-ink-muted">
                {recommendation.date}
            </p>
        </div>
    </footer>
</article>
