---
import { EDUCATION } from "../../data/EDUCATION"
---

<section id="education" class="scroll-mt-24 pb-24 md:pb-32" aria-labelledby="education-heading">
    <div class="mb-8 grid gap-5 md:grid-cols-12 md:items-end">
        <div class="md:col-span-7">
            <p class="mb-3 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-coral">
                Academic foundations
            </p>
            <h2
                id="education-heading"
                class="max-w-2xl text-3xl font-black leading-tight tracking-[-0.035em] text-ink md:text-5xl"
            >
                Education <span class="font-display font-normal italic">& foundations</span>
            </h2>
            <p class="mt-4 font-mono text-xs text-ink-muted">cat ~/history/education.md</p>
        </div>
        <p class="max-w-md text-sm leading-relaxed text-ink-muted md:col-span-5 md:justify-self-end md:text-base">
            Two connected qualifications in computer engineering, completed at Enginyeria La Salle.
        </p>
    </div>

    <ol class="grid gap-5 lg:grid-cols-2">
        {
            EDUCATION.map((education, index) => (
                <li>
                    <article class="flex h-full flex-col rounded-3xl border border-ink/5 bg-white p-6 md:p-8">
                        <div class="flex items-start justify-between gap-4">
                            <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-coral">
                                {String(index + 1).padStart(2, "0")} / Qualification
                            </p>
                            <span class="rounded-full bg-sea/10 px-3 py-1.5 font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-sea">
                                Grade: {education.grade}
                            </span>
                        </div>

                        <h3 class="mt-8 max-w-xl text-2xl font-black leading-tight tracking-[-0.035em] text-ink md:text-3xl">
                            {education.qualification}
                        </h3>
                        <p class="mt-3 text-lg font-black text-sea">{education.institution}</p>
                        <p class="mt-2 font-mono text-[0.65rem] leading-relaxed text-ink-muted">
                            {education.originalQualification}
                        </p>

                        <div class="mt-8 border-t border-ink/10 pt-6">
                            <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-coral">
                                Final degree project · {education.projectArea}
                            </p>
                            <p class="mt-3 text-sm font-semibold leading-relaxed text-ink md:text-base">
                                {education.project}
                            </p>
                        </div>
                    </article>
                </li>
            ))
        }
    </ol>
</section>
