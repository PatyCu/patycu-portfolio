---
import { OFF_HOURS_CARDS } from "../../data/OFF_HOURS"
---

<section id="off-hours" class="scroll-mt-24 pb-24 md:pb-32" aria-labelledby="off-hours-heading">
    <div class="mb-8 grid gap-5 md:grid-cols-12 md:items-end">
        <div class="md:col-span-7">
            <p class="mb-3 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-coral">
                Away from the keyboard
            </p>
            <h2
                id="off-hours-heading"
                class="max-w-2xl text-3xl font-black leading-tight tracking-[-0.035em] text-ink md:text-5xl"
            >
                Life <span class="font-display font-normal italic">off-hours</span>
            </h2>
            <p class="mt-4 font-mono text-xs text-ink-muted">ls ~/life/beyond-work</p>
        </div>
        <p class="max-w-md text-sm leading-relaxed text-ink-muted md:col-span-5 md:justify-self-end md:text-base">
            A small window into the things that keep me curious, grounded, and inspired. Stories and photos are coming
            soon.
        </p>
    </div>

    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
            OFF_HOURS_CARDS.map((card, index) => (
                <li class:list={[index === 0 && "sm:col-span-2 lg:col-span-1"]}>
                    <article
                        class:list={[
                            "group flex min-h-72 h-full flex-col overflow-hidden rounded-[1.75rem] p-7 transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-soft",
                            card.theme
                        ]}
                    >
                        <div class="flex items-start justify-between gap-4">
                            <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.16em] opacity-65">
                                {String(index + 1).padStart(2, "0")} / Off-hours
                            </p>
                            <span class="rounded-full border border-current/20 px-3 py-1 font-mono text-[0.58rem] font-semibold uppercase tracking-[0.12em] opacity-70">
                                More soon
                            </span>
                        </div>

                        <p
                            class="mt-8 text-6xl font-black leading-none tracking-[-0.055em] transition-transform duration-300 group-hover:-rotate-3 group-hover:scale-105"
                            aria-hidden="true"
                        >
                            {card.marker}
                        </p>
                        <h3 class="mt-auto max-w-[13rem] pt-10 text-2xl font-black leading-tight tracking-[-0.035em]">
                            {card.title}
                        </h3>
                    </article>
                </li>
            ))
        }
    </ul>
</section>
