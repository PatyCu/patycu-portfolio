---
import Batch from "../ui/Batch.astro"

interface Props {
    title: string
    image?: string | null
    link?: string | null
    github?: string | null
    description: string
    tags?: string[]
}

const { title, image, link, github, description, tags } = Astro.props
const projectUrl = github || link
---

<li class="p-2 bg-slate-600/50 my-2 w-[300px] border border-transparent rounded-lg">
    <div>
        <h3 class="text-cyan-500">{title}</h3>
        {
            image ? (
                <img src={image} alt={`${title} screenshot`} class="my-2 w-full rounded-lg" />
            ) : (
                <div class="my-2 grid aspect-[3/2] place-items-center rounded-lg border border-dashed border-cyan-500/40 bg-slate-950/20 px-6 text-center font-mono text-xs uppercase tracking-widest text-cyan-500/80">
                    Interactive CV in progress
                </div>
            )
        }
        {
            projectUrl && (
                <p>
                    <a href={projectUrl} class="text-sm text-slate-300/80 hover:text-cyan-500/80">
                        {projectUrl}
                    </a>
                </p>
            )
        }
        <p>{description}</p>
        <div>
            {tags && tags.map((tag: string) => <Batch color="blue">{tag}</Batch>)}
        </div>
    </div>
</li>
