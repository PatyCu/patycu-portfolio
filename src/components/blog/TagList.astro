---
interface Props {
    tags: string[]
    activeTag?: string
}

const { tags, activeTag } = Astro.props
---

<ul class="flex flex-wrap gap-2">
    {
        tags.map((tag) => (
            <li class="flex">
                <a
                    href={`/blog?tag=${encodeURIComponent(tag)}`}
                    class={`rounded-full border px-3 py-1.5 text-xs font-bold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-coral ${
                        tag === activeTag
                            ? "border-sea bg-sea text-cream"
                            : "border-ink/15 bg-cream text-ink-muted hover:border-sea hover:text-sea"
                    }`}
                    aria-current={tag === activeTag ? "page" : undefined}
                >
                    {tag}
                </a>
            </li>
        ))
    }
</ul>
