---
const { post } = Astro.props
---

<article
    class="group flex h-full flex-col rounded-3xl border border-ink/10 bg-white p-6 shadow-[0_12px_40px_rgb(11_19_36/0.07)] transition duration-300 hover:-translate-y-1 hover:border-sea/30 hover:shadow-soft sm:p-8"
>
    <div
        class="mb-6 flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-ink-muted"
    >
        <time datetime={post.frontmatter.pubDate.slice(0, 10)}>{post.frontmatter.pubDate.slice(0, 10)}</time>
        <span class="size-1 rounded-full bg-coral" aria-hidden="true"></span>
        <span>{post.frontmatter.author}</span>
    </div>

    <h2 class="text-balance text-2xl font-black leading-tight tracking-[-0.03em] text-ink sm:text-3xl">
        {post.frontmatter.title}
    </h2>

    <p class="mt-4 flex-1 text-base leading-relaxed text-ink-muted">{post.frontmatter.description}</p>

    <a
        href={post.url}
        class="mt-7 inline-flex w-fit items-center gap-2 rounded-sm text-sm font-black text-sea transition-colors hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-coral"
    >
        Read article <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
    </a>
</article>
